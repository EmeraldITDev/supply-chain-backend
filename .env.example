APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Use https in production (e.g. Render) or SPA pages load API URLs as mixed content (blocked).
APP_URL=http://localhost
# Laravel app timezone (Carbon, date displays). e.g. Africa/Lagos — leave unset for UTC.
# APP_TIMEZONE=UTC

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=resend
MAIL_SCHEME=null
MAIL_HOST=smtp.resend.com
MAIL_PORT=587
MAIL_USERNAME=resend
MAIL_PASSWORD=your_resend_api_key_here
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# Comma-separated CC for logistics/fleet workflow emails (defaults in config/scm.php).
# LOGISTICS_NOTIFICATION_CC_EMAILS=joseph.akinyanmi@emeraldcfze.com
RESEND_API_KEY=your_resend_api_key_here
FRONTEND_URL=https://your-frontend-domain.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

PO_CC_RECIPIENTS=lateef.olanrewaju@emeraldcfze.com,bunmi.babajide@emeraldcfze.com
PO_GENERATED_TO_RECIPIENTS=viva.musa@emeraldcfze.com
PO_INVOICE_SUBMISSION_EMAIL=accountpayables@emeraldcfze.com
PO_INVOICE_SUBMISSION_CC=lateef.olanrewaju@emeraldcfze.com
