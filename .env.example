APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Use https in production (e.g. Render) or SPA pages load API URLs as mixed content (blocked).
APP_URL=http://localhost
# Laravel app timezone (Carbon, date displays). e.g. Africa/Lagos — leave unset for UTC.
# APP_TIMEZONE=UTC

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=resend
MAIL_SCHEME=null
MAIL_HOST=smtp.resend.com
MAIL_PORT=587
MAIL_USERNAME=resend
MAIL_PASSWORD=your_resend_api_key_here
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# Comma-separated CC for logistics/fleet workflow emails (defaults in config/scm.php).
# LOGISTICS_NOTIFICATION_CC_EMAILS=joseph.akinyanmi@emeraldcfze.com
RESEND_API_KEY=your_resend_api_key_here
FRONTEND_URL=https://your-frontend-domain.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

PO_CC_RECIPIENTS=lateef.olanrewaju@emeraldcfze.com,bunmi.babajide@emeraldcfze.com
PO_GENERATED_TO_RECIPIENTS=viva.musa@emeraldcfze.com
PO_INVOICE_SUBMISSION_EMAIL=accountpayables@emeraldcfze.com
PO_INVOICE_SUBMISSION_CC=lateef.olanrewaju@emeraldcfze.com

# -----------------------------------------------------------------------------
# Finance AP integration (SCM ↔ financeap-backend)
# Spec: docs/FINANCE_AP_SIDE_SCM_INTEGRATION.md
#
# API keys are NOT issued by a third-party dashboard. You generate them once
# (long random strings) and set the SAME values on BOTH apps:
#   - this repo (supply-chain-backend) — below
#   - financeap-backend — see financeap-backend/.env.scm.example
#
# Generate locally (pick one):
#   openssl rand -hex 32
#   php -r "echo bin2hex(random_bytes(32)), PHP_EOL;"
#
# | Purpose                         | SCM (.env here)              | Finance AP (.env)              |
# |---------------------------------|------------------------------|--------------------------------|
# | SCM pushes packages TO Finance AP | FINANCE_AP_API_KEY           | SCM_INTEGRATION_API_KEY        |
# | Finance AP pulls doc refresh      | FINANCE_AP_INTEGRATION_...   | SCM_OUTBOUND_API_KEY           |
# | Webhook HMAC (FA → SCM)           | FINANCE_AP_WEBHOOK_SECRET    | SCM_WEBHOOK_SECRET             |
# -----------------------------------------------------------------------------

# Where SCM sends packages (Finance AP API). Production Render URL shown; use local URL when testing FA locally.
FINANCE_AP_BASE_URL=https://financeap-backend.onrender.com

# Secret SCM sends as X-Api-Key when calling Finance AP ingest/delta endpoints.
# Must match financeap-backend SCM_INTEGRATION_API_KEY exactly.
FINANCE_AP_API_KEY=

# Secret Finance AP sends when calling SCM document refresh (X-Api-Key).
# Must match financeap-backend SCM_OUTBOUND_API_KEY (or SCM_INTEGRATION_API_KEY if outbound not set).
FINANCE_AP_INTEGRATION_INBOUND_KEY=

# Shared HMAC secret for Finance AP → SCM webhooks (header X-Finance-Ap-Signature).
# Must match financeap-backend SCM_WEBHOOK_SECRET exactly.
FINANCE_AP_WEBHOOK_SECRET=

# Set false to disable outbound push/webhook attempts (e.g. local dev without Finance AP running).
FINANCE_AP_INTEGRATION_ENABLED=true

# HTTP timeout (seconds) for calls to Finance AP.
FINANCE_AP_HTTP_TIMEOUT=30

# MRFs created on or after this date route to Finance AP (ISO date, e.g. 2026-06-01).
# Required for any Finance AP handoff — if unset, no MRFs use Finance AP integration.
FINANCE_AP_CUTOVER_DATE=2026-06-01

# Push vendor create/update snapshots to Finance AP outside package ingest.
FINANCE_AP_VENDOR_SYNC_ENABLED=true
